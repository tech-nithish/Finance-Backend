{
  "info": {
    "_postman_id": "finance-dashboard-api-v1",
    "name": "Finance Dashboard API",
    "description": "Complete Postman collection for the Finance Dashboard Backend API.\n\n**Base URL:** `http://localhost:8080`\n\n**Auth Flow:**\n1. Call `POST /api/auth/register` to create an ADMIN user\n2. Call `POST /api/auth/login` to get a JWT token\n3. Copy the `token` from the response\n4. Set it in the `Authorization` header as `Bearer <token>` for all protected endpoints\n\n**Note:** The collection variable `baseUrl` is set to `http://localhost:8080` and `token` is auto-set after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "recordId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register Admin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('userId', json.id);",
                  "    pm.test('Registration successful', () => pm.expect(pm.response.code).to.equal(200));",
                  "    pm.test('Token returned', () => pm.expect(json.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. Role can be VIEWER, ANALYST, or ADMIN.\n\nIf no role is provided, defaults to VIEWER.\n\n**Auto-sets:** `token` and `userId` collection variables."
          }
        },
        {
          "name": "Register Analyst User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Analyst User\",\n  \"email\": \"analyst@example.com\",\n  \"password\": \"analyst123\",\n  \"role\": \"ANALYST\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Viewer User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Viewer User\",\n  \"email\": \"viewer@example.com\",\n  \"password\": \"viewer123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a viewer - no role specified, defaults to VIEWER"
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('userId', json.id);",
                  "    pm.test('Login successful', () => pm.expect(pm.response.code).to.equal(200));",
                  "    pm.test('Token returned', () => pm.expect(json.token).to.be.a('string'));",
                  "    pm.test('Role is ADMIN', () => pm.expect(json.role).to.equal('ADMIN'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate and get JWT token.\n\n**Auto-sets:** `token` collection variable. Use this token in the Authorization header: `Bearer {{token}}`"
          }
        },
        {
          "name": "Login - Validation Error (empty body)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Should return 400 with validation errors for missing email and password fields."
          }
        },
        {
          "name": "Login - Wrong Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Should return 401 Unauthorized."
          }
        }
      ]
    },
